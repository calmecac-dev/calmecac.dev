---
import '../styles/global.css';
import LangToggle from '../components/LangToggle.svelte';

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const {
  title,
  description = 'Open source tools built with purpose and cultural roots.',
  lang = 'es',
} = Astro.props;

const currentPath = Astro.url.pathname;
const isEn = currentPath.startsWith('/en');

const nav = isEn
  ? [
      { href: '/en/',         label: 'Home'     },
      { href: '/en/blog',     label: 'Blog'     },
      { href: '/en/projects', label: 'Projects' },
      { href: '/en/contact',  label: 'Contact'  },
    ]
  : [
      { href: '/',            label: 'Inicio'    },
      { href: '/blog',        label: 'Blog'      },
      { href: '/projects',    label: 'Proyectos' },
      { href: '/contact',     label: 'Contacto'  },
    ];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} · Calmécac</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />

  </head>
  <body>
    <header class="site-header">
      <div class="container container--wide header-inner">
        <a href={isEn ? '/en/' : '/'} class="logo" aria-label="Calmécac — Inicio">
          <img src="/logo.svg" alt="Calmécac" width="52" height="31" />
          <span class="logo-text">Calmécac<span class="logo-tld">.dev</span></span>
        </a>

        <nav class="main-nav" aria-label="Navegación principal">
          {nav.map(({ href, label }) => (
            <a href={href} class={`nav-link ${currentPath === href ? 'active' : ''}`}>
              {label}
            </a>
          ))}
        </nav>

        <div class="header-actions">
          <LangToggle client:load currentPath={currentPath} isEn={isEn} />
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container container--wide footer-inner">
        <p class="footer-copy">
          © {new Date().getFullYear()} Calmécac —
          <a href="https://github.com/calmecac-dev" target="_blank" rel="noopener" aria-label="GitHub">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="vertical-align: middle;">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
          </a>
        </p>
        <p class="footer-tagline">Open source tools built with purpose and cultural roots.</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 0.5px solid var(--text-border);
    transition: background 0.2s ease;
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 72px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--text);
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  .logo:hover { color: var(--teal); }

  .logo-tld {
    color: var(--teal);
    font-weight: 400;
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
  }

  .nav-link {
    font-size: 0.9rem;
    color: var(--text-muted);
    padding: 0.4rem 0.75rem;
    border-radius: var(--radius-sm);
    transition: color 0.15s, background 0.15s;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text);
    background: var(--bg-card);
  }

  .nav-link.active { font-weight: 500; }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
  }

  .site-footer {
    margin-top: 6rem;
    border-top: 0.5px solid var(--text-border);
    padding: 2rem 0;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-copy {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: var(--text-muted);
    font-style: italic;
  }

  @media (max-width: 640px) {
    .main-nav { display: none; }
    .footer-inner { flex-direction: column; align-items: flex-start; }
  }
</style>