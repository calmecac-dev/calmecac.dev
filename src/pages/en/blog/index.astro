---
import Base from '../../../layouts/Base.astro';
import PostCard from '../../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.id.startsWith('en/'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="Blog" lang="en">
  <div class="container container--wide" style="padding-top: 3rem; padding-bottom: 4rem;">
    <header class="page-header">
      <h1>Blog</h1>
      <p class="page-sub">Development, tools, software philosophy, and whatever else comes to mind.</p>
    </header>
    {posts.length > 0
      ? posts.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.id.replace('en/', '').replace('.md', '')}
            tags={post.data.tags}
            readingTime={post.data.readingTime}
            lang="en"
          />
        ))
      : <p style="color: var(--text-muted); padding: 2rem 0;">No posts yet. Check back soon.</p>
    }
  </div>
</Base>

<style>
  .page-header { margin-bottom: 2.5rem; }
  .page-sub { color: var(--text-muted); margin-top: 0.5rem; max-width: 48ch; }
</style>
