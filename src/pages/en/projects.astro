---
import Base from '../../layouts/Base.astro';
---

<Base title="Projects" lang="en">
  <div class="container container--wide" style="padding-top: 3rem; padding-bottom: 5rem;">
    <header class="page-header">
      <h1>Projects</h1>
      <p class="page-sub">Open source software built with purpose. Everything under the MIT license.</p>
    </header>

    <div class="projects-grid">

      <article class="project-card">
        <div class="project-header">
          <h2 class="project-name">Tlahtolli</h2>
          <span class="project-status status-dev">En desarrollo</span>
        </div>
        <p class="project-slogan">Modern technology in service of a millennia-old tradition of telling stories.</p>
        <p class="project-desc">
          Cross-platform creative writing editor. Inspired by Scrivener, built with open source philosophy. For writers who want a serious tool without paying for licenses.
        </p>
        <div class="project-stack">
          <span class="stack-tag">C#</span>
          <span class="stack-tag">Avalonia UI</span>
          <span class="stack-tag">XAML</span>
          <span class="stack-tag">SQLite</span>
        </div>
        <div class="project-platforms">
          <span class="platform-tag">Linux</span>
          <span class="platform-tag">macOS</span>
          <span class="platform-tag">Windows</span>
        </div>
        <div class="project-links">
          <a href="https://github.com/tlahtolli-app/tlahtolli" target="_blank" rel="noopener" class="project-link">GitHub →</a>
        </div>
      </article>

      <article class="project-card">
        <div class="project-header">
          <h2 class="project-name">Cuicatl</h2>
          <span class="project-status status-alpha">v0.1.0-alpha</span>
        </div>
        <p class="project-desc">
          Creative writing document conversion library. Two independent implementations sharing the same architecture. Reads Scrivener, RTF, and Markdown; writes Markdown, HTML, ePub, PDF, and docx.
        </p>
        <div class="project-implementations">
          <div class="impl">
            <span class="impl-name">Cuicatl (Go)</span>
            <span class="impl-desc">Go module · open source · v0.1.0-alpha</span>
            <a href="https://github.com/calmecac-dev/cuicatl" target="_blank" rel="noopener" class="impl-link">GitHub →</a>
          </div>
          <div class="impl">
            <span class="impl-name">Cuicatl.NET (C#)</span>
            <span class="impl-desc">NuGet package · core of Tlahtolli</span>
            <a href="https://github.com/calmecac-dev/cuicatl-dotnet" target="_blank" rel="noopener" class="impl-link">GitHub →</a>
          </div>
        </div>
      </article>

      <article class="project-card">
        <div class="project-header">
          <h2 class="project-name">Amatl</h2>
          <span class="project-status status-dev">En desarrollo</span>
        </div>
        <p class="project-slogan">Everything IT needs to know about its assets, in one place, no subscriptions, no servers.</p>
        <p class="project-desc">
          IT asset manager for SMBs. Inventory, assignments, warranties, maintenance, and consumables — offline, no servers, no subscriptions.
        </p>
        <div class="project-stack">
          <span class="stack-tag">Go</span>
          <span class="stack-tag">Wails</span>
          <span class="stack-tag">Svelte</span>
          <span class="stack-tag">SQLite</span>
        </div>
        <div class="project-platforms">
          <span class="platform-tag">Windows</span>
          <span class="platform-tag">Linux</span>
          <span class="platform-tag">macOS</span>
        </div>
        <div class="project-links">
          <a href="https://github.com/calmecac-dev/amatl" target="_blank" rel="noopener" class="project-link">GitHub →</a>
        </div>
      </article>

    </div>
  </div>
</Base>

<style>
  .page-header { margin-bottom: 3rem; }
  .page-sub { color: var(--text-muted); margin-top: 0.5rem; max-width: 60ch; }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .project-card {
    background: var(--bg-card);
    border: 0.5px solid var(--text-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    transition: border-color 0.15s;
  }

  .project-card:hover { border-color: var(--teal); }

  .project-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .project-name { font-size: 1.25rem; margin: 0; }

  .project-status {
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }

  .status-dev {
    background: color-mix(in srgb, var(--terracota) 15%, transparent);
    color: var(--terracota);
  }

  .status-alpha {
    background: color-mix(in srgb, var(--teal) 15%, transparent);
    color: var(--teal);
  }

  .project-slogan {
    font-size: 0.875rem;
    font-style: italic;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .project-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.65;
    flex: 1;
  }

  .project-stack, .project-platforms {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .stack-tag {
    font-size: 0.72rem;
    font-weight: 500;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    border: 0.5px solid var(--text-border);
    color: var(--text-muted);
  }

  .platform-tag {
    font-size: 0.72rem;
    font-weight: 500;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--terracota) 10%, transparent);
    color: var(--terracota);
  }

  .project-implementations {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    border-top: 0.5px solid var(--text-border);
    padding-top: 0.9rem;
  }

  .impl {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: 0.1rem 0.75rem;
    align-items: center;
  }

  .impl-name {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
    grid-column: 1;
    grid-row: 1;
  }

  .impl-desc {
    font-size: 0.78rem;
    color: var(--text-muted);
    grid-column: 1;
    grid-row: 2;
  }

  .impl-link {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--teal);
    grid-column: 2;
    grid-row: 1 / 3;
    align-self: center;
  }

  .project-links { margin-top: auto; }
  .project-link { font-size: 0.875rem; font-weight: 500; color: var(--teal); }
</style>
PLACEHOLDER